# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
# export FZF_BASE=/home/linuxbrew/.linuxbrew/opt/fzf
zstyle ':omz:update' mode reminder

# Plugins
plugins=(git asdf node fzf zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

# Catppuccin Mocha syntax highlighting
source ~/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh

# --- History ---
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt APPEND_HISTORY
setopt SHARE_HISTORY

# --- PATH ---
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/bin:$PATH"

# --- SSH Agent (keychain persists across sessions, prompts once per reboot) ---
# eval "$(keychain --eval --quiet id_ed25519)"

# --- Homebrew (Linuxbrew) ---
# eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# --- Environment Variables ---
export EDITOR='nvim'
export GIT_EDITOR='nvim'
export GIT_SEQUENCE_EDITOR='nvim'
export HOMEBREW_NO_AUTO_UPDATE=1

# --- Aliases (core) ---
alias vim='nvim'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# --- Aliases (tools & shortcuts) ---
alias dotconfig='nvim ~/.config'
alias zshrc='nvim ~/.zshrc'
alias tools='cat ~/.tool-versions'
alias ta='tmux a -t'
alias tls='tmux ls'
alias detach='tmux detach'
alias dockerstart='systemctl start docker'
alias dockerstop='systemctl stop docker'
alias dockerstatus='systemctl status docker'
alias purgeimages='docker rmi -f $(docker images -a -q)'
alias purgecontainers='docker rm -f $(docker ps -a -q)'
alias masterprune='git branch | grep -v "master" | xargs git branch -D'
alias grep_3000='lsof -i tcp:3000'
alias rnew='rails new -d postgresql -c tailwind -j esbuild'

# --- BookWorm ---
alias bookworm="$HOME/Code/BookWorm/.venv/bin/bookworm"

# --- Chezmoi ---
alias sync-dotfiles='chezmoi re-add && cd ~/.local/share/chezmoi && git add -A && git commit -m "syncing dotfiles" && git push && cd -'

# --- FZF ---
eval "$(fzf --zsh)"

# --- Starship Prompt (must be last) ---
eval "$(starship init zsh)"
